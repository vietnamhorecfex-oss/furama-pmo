# ─────────────────────────────────────────────────────────────────────────────
# Furama PMO — environment. Copy to `.env` for local dev; set the same keys in
# the Vercel dashboard (Project → Settings → Environment Variables) for prod.
# ─────────────────────────────────────────────────────────────────────────────

# ---- App ----
NODE_ENV=development
# Public origin of the deployed app (used for cookies / links). Local Next dev = :3002.
WEB_ORIGIN=http://localhost:3002

# ---- Database (self-managed PostgreSQL — discrete variables, no monolithic DATABASE_URL) ----
# The connection URL is composed from these at runtime (web/src/server/db-url.ts) and for the
# Prisma CLI (scripts/db-env.mjs). Set the DIRECT Postgres endpoint here:
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=furama
POSTGRES_PASSWORD=furama
POSTGRES_DB=furama_pmo
POSTGRES_SCHEMA=public
# POSTGRES_SSLMODE=require        # set to 'require' in production
#
# PRODUCTION on Vercel (serverless): each invocation opens its own DB connection, so run a
# POOLER (PgBouncer transaction mode, or your host's built-in pooler) in front of Postgres and
# point the RUNTIME at it via these two extra vars. Migrations & seeding always use the DIRECT
# endpoint above (PgBouncer transaction mode breaks Prisma migrations/$transaction).
# POSTGRES_POOL_HOST=db.example.com
# POSTGRES_POOL_PORT=6432
#
# (Back-compat: if you set POSTGRES_HOST as above, DATABASE_URL/DIRECT_URL are ignored. If you
#  instead leave POSTGRES_HOST unset and provide DATABASE_URL/DIRECT_URL, those are used as-is.)

# ---- Auth ----
JWT_ACCESS_SECRET=change-me-dev-only-32+chars-xxxxxxxxxxxx   # MUST be >= 32 chars; strong random in prod
JWT_ACCESS_TTL=900            # access-token lifetime, seconds (15 min)
REFRESH_TTL_DAYS=7
ARGON2_MEMORY_KIB=19456       # >= 19 MiB
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1
COOKIE_SECURE=false           # MUST be true in production (HTTPS refresh cookie)

# ---- Rate limits (per IP/min) ----
RATE_LIMIT_AUTH_PER_MIN=10
RATE_LIMIT_WRITE_PER_MIN=120
RATE_LIMIT_READ_PER_MIN=600

# ---- AI assistant (optional) ----
# Set ONE of the keys to enable AI chat + digest; if both unset the app degrades
# gracefully ("not configured"). GEMINI_API_KEY takes priority when both are set.
# Get a Gemini key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=
AI_MODEL_REASONING=claude-haiku-4-5-20251001

# ---- Seed (optional overrides) ----
# SEED_ORG_SLUG=furama
# SEED_PROJECT_NAME=Furama Grand Opening 2026
# SEED_ADMIN_EMAIL=seed-admin@furama.test
# SEED_ADMIN_PASSWORD=correctHorseBatteryStaple
