# ─────────────────────────────────────────────────────────────────────────────
# Furama PMO — environment. Copy to `.env` for local dev; set the same keys in
# the Vercel dashboard (Project → Settings → Environment Variables) for prod.
# ─────────────────────────────────────────────────────────────────────────────

# ---- App ----
NODE_ENV=development
# Public origin of the deployed app (used for cookies / links). Local Next dev = :3002.
WEB_ORIGIN=http://localhost:3002

# ---- Database (PostgreSQL) ----
# LOCAL: native Postgres. Set DIRECT_URL equal to DATABASE_URL.
DATABASE_URL=postgresql://furama:furama@localhost:5432/furama_pmo?schema=public
DIRECT_URL=postgresql://furama:furama@localhost:5432/furama_pmo?schema=public
#
# PRODUCTION (Neon): DATABASE_URL = POOLED endpoint (…-pooler.…, add
# `?sslmode=require&pgbouncer=true&connection_limit=1`); DIRECT_URL = the DIRECT
# (non-pooled) endpoint, used only by `prisma migrate`. Example:
#   DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/furama?sslmode=require&pgbouncer=true&connection_limit=1
#   DIRECT_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/furama?sslmode=require

# ---- Auth ----
JWT_ACCESS_SECRET=change-me-dev-only-32+chars-xxxxxxxxxxxx   # MUST be >= 32 chars; strong random in prod
JWT_ACCESS_TTL=900            # access-token lifetime, seconds (15 min)
REFRESH_TTL_DAYS=7
ARGON2_MEMORY_KIB=19456       # >= 19 MiB
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1
COOKIE_SECURE=false           # MUST be true in production (HTTPS refresh cookie)

# ---- Rate limits (per IP/min) ----
RATE_LIMIT_AUTH_PER_MIN=10
RATE_LIMIT_WRITE_PER_MIN=120
RATE_LIMIT_READ_PER_MIN=600

# ---- AI assistant (optional) ----
# If unset, the AI chat degrades gracefully ("not configured"); everything else works.
ANTHROPIC_API_KEY=
AI_MODEL_REASONING=claude-haiku-4-5-20251001

# ---- Seed (optional overrides) ----
# SEED_ORG_SLUG=furama
# SEED_PROJECT_NAME=Furama Grand Opening 2026
# SEED_ADMIN_EMAIL=seed-admin@furama.test
# SEED_ADMIN_PASSWORD=correctHorseBatteryStaple
