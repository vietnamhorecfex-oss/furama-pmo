# ---- App ----
NODE_ENV=development
API_PORT=3000
WEB_ORIGIN=http://localhost:5173
# ---- Database ----
DATABASE_URL=postgresql://furama:furama@localhost:5432/furama_pmo?schema=public
# ---- Redis (sessions, rate-limit, ws pubsub) ----
REDIS_URL=redis://localhost:6379
# ---- Auth ----
JWT_ACCESS_SECRET=change-me-dev-only-32+chars-xxxxxxxxxxxx
JWT_ACCESS_TTL=900            # 15 min (seconds)
REFRESH_TTL_DAYS=7
ARGON2_MEMORY_KIB=19456       # >= 19 MiB
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1
COOKIE_SECURE=false           # true in prod (HTTPS)
# ---- Rate limits ----
RATE_LIMIT_AUTH_PER_MIN=10
RATE_LIMIT_WRITE_PER_MIN=120
RATE_LIMIT_READ_PER_MIN=600
